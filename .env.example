# Backend runtime
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api
DATABASE_URL=sqlite:///data/app.db
UPLOAD_DIR=uploads

# OpenAI configuration
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MEAL_MODEL=gpt-5.2-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_VISION_MODEL=gpt-5.2-mini

# Strava integration placeholders (implemented in later branches)
STRAVA_CLIENT_ID=replace-with-strava-client-id
STRAVA_CLIENT_SECRET=replace-with-strava-client-secret
STRAVA_REDIRECT_URI=http://localhost:8000/api/strava/callback

# Frontend runtime
FRONTEND_API_BASE_URL=http://localhost:8000/api
